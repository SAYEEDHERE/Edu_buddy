# ─────────────────────────────────────────────────────────────
#  EduBuddy Backend — Environment Variables
#  Copy this to .env (never commit .env to git)
# ─────────────────────────────────────────────────────────────

# ── Option A: Path to service account JSON file (local dev) ──
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# ── Option B: JSON string (Render / Railway deployment) ───────
# Paste the entire serviceAccountKey.json content as a single-line
# JSON string. Only one option is needed.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ── API settings ──────────────────────────────────────────────
MODEL_VERSION=xgboost-v1.0

# ── CORS (comma-separated origins) ────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,https://your-domain.com
